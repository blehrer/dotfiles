#!/bin/bash

set -e

# Colors
#
bold() {
    if $USE_GUM; then
        gum style --bold $1
    else
        echo $1
    fi
}

grey() {
    local text="$1"
    if [[ -z "$text" ]]; then
        text="$(cat)"
    fi
    if $USE_GUM; then
        gum style --foreground 8 -- "$text"
    else
        echo -e "${GRAY}${text}${NC}"
    fi
}

debug() {
    local text="$1"
    if [[ -z "$text" ]]; then
        text="$(cat)"
    fi
    if $USE_GUM; then
        gum style --foreground 12 -- "$text"
    else
        echo -e "${BLUE}${text}${NC}"
    fi
}

info() {
    local text="$1"
    if [[ -z "$text" ]]; then
        text="$(cat)"
    fi
    if $USE_GUM; then
        gum style --foreground 10 -- "$text"
    else
        echo -e "${GREEN}${text}${NC}"
    fi
}

warn() {
    local text="$1"
    if [[ -z "$text" ]]; then
        text="$(cat)"
    fi
    if $USE_GUM; then
        gum style --foreground 11 -- "$text"
    else
        echo -e "${YELLOW}${text}${NC}"
    fi
}

err() {
    local text="$1"
    if [[ -z "$text" ]]; then
        text="$(cat)"
    fi
    if $USE_GUM; then
        gum style --foreground 9 -- "$text"
    else
        echo -e "${RED}${text}${NC}"
    fi
}

# Statuses
#
status_pass() {
    echo "✓ $1" | info | bold
}

status_fail() {
    echo "✗ $1" | err | bold
}

status_fixed() {
    echo "↻ $1" | warn | bold
}

status_skip() {
    echo "○ $1" | debug | bold
}

# Text elements
#
title() {
    echo "=== $@ ===" | debug | bold
}

p() {
    echo $1
}

li() {
    for text in "$@"; do
        echo "- $text" | grey
    done
}

section() {
    local text="$1"
    if [[ -z "$text" ]]; then
        text="$(cat)"
    fi
    echo
    echo "--- $text ---" | debug
}


if [[ "${HYPRDOCTOR_NO_GUM:-}" == "1" ]]; then
    USE_GUM=false
elif command -v gum &> /dev/null; then
    USE_GUM=true
else
    USE_GUM=false
fi
if $USE_GUM; then
    :
else
    RED='\033[0;31m'
    GREEN='\033[0;32m'
    YELLOW='\033[1;33m'
    BLUE='\033[0;34m'
    GRAY='\033[0;90m'
    NC='\033[0m'
fi

title "Hyprland Monitor Diagnostics"

FAILED=()
PASSED=()
FIXED=()
SKIPPED=()

section "1. Kanshi Daemon Status"
KANSHI_COUNT=$(pgrep -cx kanshi 2>/dev/null | tr -d '[:space:]' || echo "0")

if [[ "$KANSHI_COUNT" -gt 1 ]]; then
    warn "Found $KANSHI_COUNT stale kanshi processes - cleaning up"
    pkill kanshi
    sleep 0.5
    KANSHI_COUNT=0
fi

if [[ "$KANSHI_COUNT" -eq 1 ]]; then
    info "kanshi process: RUNNING (1 instance)"
    PASSED+=("kanshi daemon running")
elif [[ "$KANSHI_COUNT" -eq 0 ]]; then
    err "kanshi process: NOT RUNNING"
    FAILED+=("kanshi daemon running")
    grey "Starting kanshi..."
    uwsm-app -- kanshi &
    sleep 1
    if pgrep -x kanshi > /dev/null 2>&1; then
        info "Started!"
        FIXED+=("kanshi daemon running")
        FAILED=("${FAILED[@]/$'kanshi daemon running'}")
    else
        err "Failed to start"
    fi
fi

section "2. Hyprland Monitor Detection"
HYPR_MONITORS=$(hyprctl monitors -j 2>/dev/null || echo "[]")
grey "Detected monitors:"
mapfile -t MONITOR_LINES < <(echo "$HYPR_MONITORS" | jq -r '.[] | "\(.name): \(.width)x\(.height)@\(.refreshRate) Hz"' 2>/dev/null)
if [[ ${#MONITOR_LINES[@]} -gt 0 ]] && [[ -n "${MONITOR_LINES[0]}" ]]; then
    li "${MONITOR_LINES[@]}"
else
    grey "(failed to parse)"
fi

LAPTOP_MONITOR=$(echo "$HYPR_MONITORS" | jq -r '.[] | select(.name | startswith("eDP")) | .name' 2>/dev/null)
HDMI_MONITOR=$(echo "$HYPR_MONITORS" | jq -r '.[] | select(.name | contains("HDMI")) | .name' 2>/dev/null)

if [[ -n "$LAPTOP_MONITOR" ]]; then
    info "Laptop display: $LAPTOP_MONITOR"
    PASSED+=("Laptop monitor detected")
else
    err "Laptop display: not detected"
    FAILED+=("Laptop monitor detection")
fi

if [[ -n "$HDMI_MONITOR" ]]; then
    info "HDMI display: $HDMI_MONITOR"
    PASSED+=("HDMI monitor detected")
else
    warn "HDMI display: not connected"
    SKIPPED+=("HDMI monitor (not connected)")
fi

section "3. Kanshi Configuration Validation"
KANSHI_CONFIG="$HOME/.config/kanshi/config"
if [[ -f "$KANSHI_CONFIG" ]]; then
    status_pass "kanshi config exists"
    PASSED+=("kanshi config exists")

    CONFIG_LAPTOP=$(grep -oP 'output \K[a-zA-Z0-9\-]+' "$KANSHI_CONFIG" | head -1)
    CONFIG_HDMI=$(grep -oP 'output \K[a-zA-Z0-9\-]+' "$KANSHI_CONFIG" | grep -i hdmi | head -1)

    grey "  Config expects laptop: $CONFIG_LAPTOP"
    grey "  Config expects HDMI: $CONFIG_HDMI"

    if [[ "$CONFIG_LAPTOP" == "$LAPTOP_MONITOR" ]] || [[ -z "$LAPTOP_MONITOR" ]]; then
        info "  Laptop match: OK"
    else
        warn "  Laptop match: mismatch (may work anyway)"
    fi
else
    err "kanshi config not found at $KANSHI_CONFIG"
    FAILED+=("kanshi config missing")
fi

section "4. Kanshi Event Testing"
grey "Reloading kanshi configuration..."
if kanshictl reload 2>/dev/null; then
    info "kanshictl reload: SUCCESS"
    PASSED+=("kanshi reload")
else
    err "kanshictl reload: FAILED"
    FAILED+=("kanshi reload")
fi

echo "Waiting for profile to apply..."
if $USE_GUM; then
    gum spin --title "Applying..." -- sleep 2 2>/dev/null || sleep 2
else
    sleep 2
fi

NEW_MONITORS=$(hyprctl monitors -j 2>/dev/null)
grey "Monitors after reload:"
mapfile -t NEW_MONITOR_LINES < <(echo "$NEW_MONITORS" | jq -r '.[] | .name' 2>/dev/null)
if [[ ${#NEW_MONITOR_LINES[@]} -gt 0 ]] && [[ -n "${NEW_MONITOR_LINES[0]}" ]]; then
    li "${NEW_MONITOR_LINES[@]}"
else
    grey "(failed to parse)"
fi

section "5. Lid Switch Status"
LID_STATE=$(cat /proc/acpi/button/lid/LID*/state 2>/dev/null | head -1 | awk '{print $2}' || echo "unknown")
grey "Lid state: $LID_STATE"

section "6. Hyprland Bindings"
BINDINGS=$(hyprctl bindings -j 2>/dev/null || echo "[]")
LID_BINDINGS=$(echo "$BINDINGS" | jq -r '.[] | select(.type == "lid" or .type == "switch") | .type + ": " + .keyd' 2>/dev/null || true)
if [[ -n "$LID_BINDINGS" ]]; then
    grey "Active lid/switch bindings:"
    while read -r binding; do
        li "$binding"
    done <<< "$LID_BINDINGS"
else
    info "No conflicting lid bindings (good)"
    PASSED+=("No conflicting bindings")
fi

section "7. Testing"
grey "Monitor hotplug test: unplug and replug HDMI, then run hyprdoctor again"
grey "Lid switch test: close and open lid, then run hyprdoctor again"

section "Summary"
echo

if [[ ${#PASSED[@]} -gt 0 ]]; then
    echo
    status_pass "Passed: ${#PASSED[@]}"
    for item in "${PASSED[@]}"; do
        info "$item"
    done
fi

if [[ ${#FIXED[@]} -gt 0 ]]; then
    echo
    status_fixed "Fixed: ${#FIXED[@]}"
    for item in "${FIXED[@]}"; do
        warn "$item"
    done
fi

if [[ ${#FAILED[@]} -gt 0 ]]; then
    echo
    status_fail "Failed: ${#FAILED[@]}"
    for item in "${FAILED[@]}"; do
        err "$item"
    done
fi

if [[ ${#SKIPPED[@]} -gt 0 ]]; then
    echo
    status_skip "Skipped: ${#SKIPPED[@]}"
    for item in "${SKIPPED[@]}"; do
        debug "$item"
    done
fi

echo
if [[ ${#FAILED[@]} -eq 0 ]]; then
    info "All checks passed!"
    grey "Your monitor setup should be working. Try:"
    li "Plug/unplug HDMI cable" "Close/open laptop lid" "Run hyprdoctor again if issues persist"
else
    warn "Some checks failed. Next steps:"
    echo
    grey "Manual diagnostics to run:"
    li "journalctl --user -u kanshi -f # Watch live events" "hyprctl monitors # See current state" "kanshictl reload # Force reload" "systemctl --user status kanshi # Daemon status"
    echo
    grey "If kanshi isn't responding to events, try:"
    li "Kill kanshi: pkill kanshi" "Restart it: uwsm-app -- kanshi" "Check config: kanshictl config-validate"
fi
