shellenv=$(ps -o cmd= -p $$ | xargs basename)
test -d ~/.local/share/omarchy && is_omarchy=true
cz_base=~/.local/share/chezmoi/assets/shell-environment
omarchy_base=~/.local/share/omarchy/default/bash
if [[ $is_omarchy = 'true' ]]; then
    if [[ $shellenv = 'zsh' ]]; then
        for f in envs functions aliases; do
            source $omarchy_base/$f
        done
        inits=$(cat $omarchy_base/init | sed -e 's/bash/zsh/g')
        eval $inits
    fi
    source $cz_base/undo_omacom
fi
for f in shell envs functions aliases init; do
    source $cz_base/$f
done

