# ((( Gradle
function gw {
    [ -n 'gradlew' ] && ./gradlew $@ && return
    local tld=$(git rev-parse --show-toplevel)
    if [ $? ]; then
        eq=$(test $(pwd) = "${tld}")
        "${eq}" || pushd "${tld}"
        ./gradlew $@
        "${eq}" || popd
    fi
}
