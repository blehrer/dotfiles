if has yazi  ; then
    function y {
        local tmp="$(mktemp -t "yazi-cwd.XXXXXX")" cwd
        yazi "$@" --cwd-file="$tmp"
        IFS= read -r -d '' cwd <"$tmp"
        [ -n "$cwd" ] && [ "$cwd" != "$PWD" ] && builtin cd -- "$cwd"
        rm -f -- "$tmp"
    }
    alias ranger=y
fi

if [[ 'Darwin' = $(uname) ]]; then
    if has brew  && has jq  && has chezmoi && [[ -n "$ZSH_VERSION" ]]
    then
        source "${DOTFILES_HOME}/assets/shell-environment/brewfile"
        function brew {
            case $1 in
                install) ;&
                uninstall)
                    command brew "$@"
                    local brewfile
                    brewfile=$(brewfile_machine_path)
                    echo "Dumping changed Brewfile ($brewfile)"
                    brew bundle dump --file="$brewfile" --force
                    brewfile_autocommit "Update"
                    ;;
                *)
                    command brew "$@"
                    ;;
            esac
        }
    fi
fi

if has zellij; then
    function zellij-sesh {
        if [ $(zellij ls -n | grep -v 'EXITED - attach to resurrect' | wc -l) -le 1 ]; then
            zellij -l welcome
        else
            zellij -l $HOME/.config/zellij/layouts/launchpad.kdl
        fi
    }
fi
if [[ $(declare -f z) = $(echo "z () {\n\t__zoxide_z \"\$@\"\n}") ]];then
    alias cd=z
else
    alias cd='builtin pushd'
fi

function personal (){
  if [ -d ~/.config/.personal ] ; then
    source ~/.config/.personal/*
  fi
}

function aid() {
  if has zellij && has fzf && has agent && has zoxide && has zi; then
    zi && 
      export AI_DEV_ROOT=$(pwd) && 
      zellij --layout ~/.config/zellij/ai-dev.kdl
  fi
}

